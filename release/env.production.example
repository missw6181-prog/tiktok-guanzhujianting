# ========== 宝塔生产环境 .env 示例 ==========
# 上传解压后，复制本文件为 .env 并修改下方配置

# MySQL（与宝塔数据库面板中创建的一致）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=follow_monitor
MYSQL_PASSWORD=请改成宝塔数据库密码
MYSQL_DATABASE=follow_monitor

# 或使用完整连接串（二选一，留空 MYSQL_HOST 时生效）
# DATABASE_URL=mysql+pymysql://follow_monitor:密码@127.0.0.1:3306/follow_monitor

# JWT 登录（务必改成随机长字符串）
JWT_SECRET=请改成随机长字符串
JWT_EXPIRE_HOURS=72

# Bot Token 加密（留空则使用 JWT_SECRET）
# TOKEN_ENCRYPT_KEY=

LOG_LEVEL=INFO
RECONNECT_DELAY_SECONDS=30
FETCH_LIVE_CHECK=false

DEFAULT_MAX_MONITORS=10
DEFAULT_MAX_BOTS=10
DEFAULT_MAX_GROUPS=10
TELEGRAM_JOIN_RATE_LIMIT_PER_MINUTE=20

# 服务器访问 TikTok 需要代理时填写
# HTTPS_PROXY=http://127.0.0.1:7890

HOST=0.0.0.0
PORT=8000
SERVE_STATIC=true

# 改成你的域名（含 http/https）
CORS_ORIGINS=https://你的域名.com,https://你的域名.com/admin
