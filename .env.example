# 目标主播 TikTok unique_id（可带或不带 @，留空则启动时提示输入）
TARGET_UNIQUE_ID=

# SQLite 数据库路径
DB_PATH=data/follows.db

# 断线或下播后重连等待秒数
RECONNECT_DELAY_SECONDS=30

# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 终端显示模式: full（弹幕/进场/点赞/新关注）或 follow_only（仅新关注）
DISPLAY_MODE=follow_only

# 设为 true 时连接前检查主播是否在播（国内网络常超时，建议保持 false）
FETCH_LIVE_CHECK=false

# 可选：代理（无法连接或频繁被 TikTok 拦截时填写）
# HTTPS_PROXY=http://127.0.0.1:7890

# 可选：直接填写 room_id，跳过页面抓取（成功连接一次后会自动缓存）
# ROOM_ID=7650098750723345172

# 设为 true 时优先使用缓存 room_id（主播重新开播后旧 room_id 会静默无事件，一般保持 false）
USE_CACHED_ROOM_ID=false

# 可选：TikTok 登录 cookie（一般不需要）
# TIKTOK_SESSION_ID=
# TIKTOK_TT_TARGET_IDC=

# Telegram 推送（群组 ID 留空则该类不推送）
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# 新关注 → 群组 A（留空不推送）
TELEGRAM_FOLLOW_CHAT_ID=

# 新进直播间 → 群组 B
TELEGRAM_JOIN_CHAT_ID=

# 进场 Telegram 每分钟推送上限（0=不限速）
# 用户去重：新关注查 follows 表，新进直播间查 joins 表，各自独立去重
TELEGRAM_JOIN_RATE_LIMIT_PER_MINUTE=20
