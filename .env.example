# ========== 系统配置（Web 版） ==========

# 数据库（默认 SQLite，宝塔可改为 MySQL）
# DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=mysql+pymysql://user:pass@127.0.0.1:3306/follow_monitor

# JWT 登录（生产环境务必修改）
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=72

# Bot Token 加密密钥（留空则使用 JWT_SECRET）
# TOKEN_ENCRYPT_KEY=

# 日志与重连
LOG_LEVEL=INFO
RECONNECT_DELAY_SECONDS=30
FETCH_LIVE_CHECK=false

# 默认用户配额
DEFAULT_MAX_MONITORS=10
DEFAULT_MAX_BOTS=10
DEFAULT_MAX_GROUPS=10
TELEGRAM_JOIN_RATE_LIMIT_PER_MINUTE=20

# 代理（服务器连 TikTok 需要时填写）
# HTTPS_PROXY=http://127.0.0.1:7890

# TikTok Cookie（一般不需要）
# TIKTOK_SESSION_ID=
# TIKTOK_TT_TARGET_IDC=

# TikTok 签名服务 API Key（请在每个监控任务中单独配置，全局不可重复）
# https://www.eulerstream.com/pricing
# SIGN_API_KEY=

# 服务监听（生产发布包 start.sh 会设置 SERVE_STATIC=true）
# HOST=0.0.0.0
# PORT=8000
# SERVE_STATIC=true

# 前端开发跨域
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
